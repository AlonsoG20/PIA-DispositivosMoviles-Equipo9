<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivBus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_truck"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/teal_primary" />

        <TextView
            android:id="@+id/tvNumeroEconomico"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="U-102"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:layout_constraintStart_toEndOf="@id/ivBus"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/chipEstado" />

        <TextView
            android:id="@+id/tvUnidadPlaca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Placas: ABC-1234"
            android:textSize="13sp"
            android:textColor="@color/gray_hint"
            app:layout_constraintStart_toStartOf="@id/tvNumeroEconomico"
            app:layout_constraintTop_toBottomOf="@id/tvNumeroEconomico" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disponible"
            android:textSize="11sp"
            app:chipMinTouchTargetSize="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvConductor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Conductor: (Sin asignar)"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@id/tvUnidadPlaca"
            app:layout_constraintTop_toBottomOf="@id/tvUnidadPlaca" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#EEEEEE"
            app:layout_constraintTop_toBottomOf="@id/tvConductor" />

        <!-- Sección de Gasolina -->
        <LinearLayout
            android:id="@+id/layoutGas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/divider">

            <TextView
                android:id="@+id/tvGasolinaInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Combustible: 50/100 L"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <ProgressBar
                android:id="@+id/pbGasolina"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:progress="50"
                android:progressTint="@color/teal_primary" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRefuel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargar Gasolina"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutGas" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>