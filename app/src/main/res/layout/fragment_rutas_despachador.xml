<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ESTADO 1: LISTA DE CHOFERES DISPONIBLES -->
    <LinearLayout
        android:id="@+id/layoutListaChoferes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asignar Nueva Ruta"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona un chofer disponible para comenzar"
            android:textColor="@color/gray_hint"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChoferesRutas"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            tools:listitem="@layout/item_chofer_simple" />
    </LinearLayout>

    <!-- ESTADO 2: CREADOR DE RUTA (MAPA + PARADAS) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutMapaAsignacion"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/mapViewDespachador"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Buscador / Input de parada -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/btnBackToList"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_expand_less"
                    android:rotation="-90"
                    app:tint="@color/gray_hint" />

                <EditText
                    android:id="@+id/etBuscarParada"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Buscar dirección o punto..."
                    android:background="@null"
                    android:padding="12dp"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/btnAddParadaTexto"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/teal_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Lista de paradas seleccionadas (Poder deseleccionar) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvParadasSeleccionadas"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:padding="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toTopOf="@id/cardConfirmar"
            tools:listitem="@layout/item_parada_mini" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardConfirmar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="10dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvChoferSeleccionadoInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asignando a: Juan Pérez"
                    android:textStyle="bold"
                    android:textColor="@color/teal_primary" />

                <Button
                    android:id="@+id/btnEnviarRutaFinal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Enviar Ruta al Chofer"
                    android:backgroundTint="@color/teal_primary"
                    android:textColor="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>