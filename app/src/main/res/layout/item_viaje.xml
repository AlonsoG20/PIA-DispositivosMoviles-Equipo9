<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Recorrido"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvEstado"/>

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:background="@drawable/button_background"
            android:backgroundTint="#F5F5F5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvDistancia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitulo"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvUnidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="km recorridos"
            android:textSize="12sp"
            android:textColor="@color/gray_hint"
            app:layout_constraintBottom_toBottomOf="@id/tvDistancia"
            app:layout_constraintStart_toEndOf="@id/tvDistancia"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicio: 00/00/00"
            android:textSize="11sp"
            android:textColor="@color/gray_hint"
            app:layout_constraintTop_toBottomOf="@id/tvEstado"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvFechaFin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fin: 00/00/00"
            android:textSize="11sp"
            android:textColor="@color/gray_hint"
            app:layout_constraintTop_toBottomOf="@id/tvFecha"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvDetalleChofer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unidad: --- | Chofer: ---"
            android:textSize="12sp"
            android:textColor="@color/teal_primary"
            app:layout_constraintTop_toBottomOf="@id/tvDistancia"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#E0F2F1"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetalleChofer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvCosto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="costo: $0"
            android:textSize="12sp"
            android:textColor="@color/gray_hint"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvCombustible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="combustible: 0.0L"
            android:textSize="12sp"
            android:textColor="@color/gray_hint"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvVerDetalleHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver detalles >"
            android:textSize="10sp"
            android:textStyle="italic"
            android:textColor="@color/teal_primary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvCosto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>