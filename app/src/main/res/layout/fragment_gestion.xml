<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- MENU PRINCIPAL DE GESTIÓN -->
    <LinearLayout
        android:id="@+id/layoutMenuGestion"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panel de Gestión"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="24dp" />

        <!-- Opción: Solicitudes -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuSolicitudes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/teal_primary" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Solicitudes de Acceso"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_expand_less"
                    android:rotation="90" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Opción: Instrucciones -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuInstrucciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_reportes"
                    app:tint="@color/teal_primary" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Instrucciones"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_expand_less"
                    android:rotation="90" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Opción: Flota -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuFlota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_truck"
                    app:tint="@color/teal_primary" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Control de Flota"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_expand_less"
                    android:rotation="90" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Opción: Personal -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuPersonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_gestion"
                    app:tint="@color/teal_primary" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Gestión de Personal"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_expand_less"
                    android:rotation="90" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Opción: Historial -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_registros"
                    app:tint="@color/teal_primary" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Historial de Viajes"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_expand_less"
                    android:rotation="90" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- CONTENEDOR DE DETALLE (Para mostrar cada sección por separado) -->
    <LinearLayout
        android:id="@+id/layoutDetalleGestion"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSubtituloGestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Detalle"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:background="@color/white"
            android:elevation="2dp" />

        <LinearLayout
            android:id="@+id/layoutFiltrosInstrucciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@color/white"
            android:visibility="gone">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFiltroGralTodos"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Todos"
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:layout_marginEnd="4dp"
                        app:cornerRadius="18dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFiltroGralPendiente"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Pend."
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:layout_marginEnd="4dp"
                        app:cornerRadius="18dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFiltroGralGuardada"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Guard."
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:layout_marginEnd="4dp"
                        app:cornerRadius="18dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFiltroGralCompletada"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Compl."
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:layout_marginEnd="4dp"
                        app:cornerRadius="18dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFiltroGralDescartada"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Desc."
                        android:textSize="10sp"
                        android:padding="0dp"
                        app:cornerRadius="18dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFiltroBloqueo"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Bloqueados: Todos"
                    android:textSize="10sp"
                    android:paddingHorizontal="8dp"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="8dp" />

                <Spinner
                    android:id="@+id/spinnerFiltroMes"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/containerGestionContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Contenido dinámico (RecyclerViews o Formas) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGestionGeneric"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/tvEmptyGestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_registros"
                    android:alpha="0.3"
                    app:tint="@color/black" />

                <TextView
                    android:id="@+id/tvEmptyTextGestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="No hay datos para mostrar"
                    android:textSize="16sp"
                    android:textColor="#888888"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Aquí se insertarán layouts específicos si es necesario -->
            <include
                android:id="@+id/layoutHistorialInGestion"
                layout="@layout/fragment_historial"
                android:visibility="gone" />

            <!-- Botón flotante ahora sobrepuesto -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddGestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|bottom"
                android:layout_margin="24dp"
                android:src="@android:drawable/ic_input_add"
                android:visibility="gone"
                app:tint="@color/white"
                app:backgroundTint="@color/teal_primary" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>