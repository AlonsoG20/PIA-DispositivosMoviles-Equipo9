<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@android:color/white"
    android:elevation="8dp"
    android:padding="8dp">

    <!-- 1. CUENTA (Siempre al principio) -->
    <LinearLayout
        android:id="@+id/nav_cuenta"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/nav_pill_background_selector"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/nav_rutas"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_person"
            app:tint="@color/nav_text_color_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cuenta"
            android:textColor="@color/nav_text_color_selector"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 2. RUTAS (Operativo) -->
    <LinearLayout
        android:id="@+id/nav_rutas"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/nav_pill_background_selector"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/nav_historial"
        app:layout_constraintStart_toEndOf="@+id/nav_cuenta"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_rutas"
            app:tint="@color/nav_text_color_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rutas"
            android:textColor="@color/nav_text_color_selector"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 3. HISTORIAL (Operativo) -->
    <LinearLayout
        android:id="@+id/nav_historial"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/nav_pill_background_selector"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/nav_gestion"
        app:layout_constraintStart_toEndOf="@+id/nav_rutas"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_registros"
            app:tint="@color/nav_text_color_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historial"
            android:textColor="@color/nav_text_color_selector"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 4. GESTIÓN (Gerente) -->
    <LinearLayout
        android:id="@+id/nav_gestion"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/nav_pill_background_selector"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/nav_reportes"
        app:layout_constraintStart_toEndOf="@+id/nav_historial"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_gestion"
            app:tint="@color/nav_text_color_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión"
            android:textColor="@color/nav_text_color_selector"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 5. REPORTES (Gerente) -->
    <LinearLayout
        android:id="@+id/nav_reportes"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/nav_pill_background_selector"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/nav_gestion"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_reportes"
            app:tint="@color/nav_text_color_selector" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reportes"
            android:textColor="@color/nav_text_color_selector"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>